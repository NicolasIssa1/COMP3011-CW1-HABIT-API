                },
                "type": "object",
                "title": "HTTPValidationError"
            },
            "HabitCreate": {
                "properties": {
                    "name": {
                        "type": "string",
                        "maxLength": 120,
                        "minLength": 1,
                        "title": "Name",
                        "description": "Name of the habit"
                    },
                    "description": {
                        "anyOf": [
                            {
                                "type": "string",
                                "maxLength": 500
                            },
